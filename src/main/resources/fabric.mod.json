{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Adds the ability to see the hex code of a color on hover in a couple scenarios.",
  "authors": [
    "Kitlith"
  ],
  "contact": {
    "homepage": "https://kitl.ing",
    "sources": "https://github.com/kitlith/painting-color-picker"
  },
  "license": "MIT",
  "icon": "assets/template/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "pw.kitl.colorpicker.ColorPickerMod"
    ]
  },
  "mixins": [
    "picker.mixins.json",
    "dev-fix.mixins.json"
  ],
  "accessWidener": "template.ct",
  "depends": {
    "fabricloader": ">=0.17",
    "minecraft": "${minecraft}"
  }
}